# Configuração isolada para Gemma 4 26B Remote Server
# Este ficheiro é usado apenas por este projeto isolado
# NÃO afeta configurações de waphix-ai-os ou waphix-ao-os-v0.5

# ============================================================================
# SERVIDOR
# ============================================================================
SERVER_PORT=8090
SERVER_HOST=0.0.0.0

# ============================================================================
# MODELO
# ============================================================================
# Path absoluto para o modelo GGUF (READ-ONLY, não modifica ficheiro)
MODEL_PATH=/home/mike/waphix-ao-os-v0.5/models/gemma-4-26B-A4B-it-qat-UD-Q4_K_XL.gguf

# Nome do modelo para API OpenAI-compatible
MODEL_NAME=gemma-4-26b-a4b-q4kxl

# ============================================================================
# BACKEND
# ============================================================================
# Path absoluto para o backend llama.cpp Vulkan (READ-ONLY)
BACKEND_PATH=/home/mike/waphix-ao-os-v0.5/runtimes/vulkan

# Tipo de backend (Vulkan obrigatório para Gemma 4 26B A4B)
BACKEND_TYPE=vulkan

# ============================================================================
# CONFIGURAÇÃO LLM
# ============================================================================
# NGL (n_gpu_layers): 14 = ~6.8 GB VRAM (seguro para RX 6600 8GB)
# 15 = borderline (~7.3 GB), 16+ = OOM
NGL=14

# Context size: 4096 tokens (limite SWA window=1024)
CTX_SIZE=4096

# N predict: 2048 tokens máximo de geração
N_PREDICT=2048

# ============================================================================
# VARIÁVEIS DE AMBIENTE VULKAN
# ============================================================================
# Força uso de GPU AMD RX 6600 (exclui GT710 e Lavapipe)
VK_ICD_FILENAMES=/usr/share/vulkan/icd.d/radeon_icd.json

# Seleciona device 0 (RX 6600)
GGML_VK_DEVICE=0

# ============================================================================
# LOGS
# ============================================================================
# Diretório para logs isolados
LOG_DIR=/home/mike/CascadeProjects/gemma-4-26b-remote/logs

# Ficheiro de log stdout
LOG_OUT=server-out.log

# Ficheiro de log stderr
LOG_ERR=server-err.log

# ============================================================================
# ESTADO
# ============================================================================
# Diretório para estado do processo
STATE_DIR=/home/mike/CascadeProjects/gemma-4-26b-remote/state

# Ficheiro para guardar PID do processo
PID_FILE=server.pid

# ============================================================================
# API OPENAI-COMPATIBLE
# ============================================================================
# Habilita endpoint /v1/chat/completions (OpenAI-compatible)
ENABLE_OPENAI_API=true

# Habilita streaming
ENABLE_STREAMING=true

# ============================================================================
# NOTAS DE CONFIGURAÇÃO
# ============================================================================
# - Este ficheiro é carregado pelos scripts deste projeto
# - Paths são absolutos para evitar ambiguidade
# - Todos os recursos são READ-ONLY (modelos, backends)
# - Logs e estado são isolados neste projeto
# - Zero impacto em projetos existentes
# ============================================================================
